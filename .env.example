# ── API Keys ────────────────────────────────────────────────────────────────
# Get your free AQICN token at: https://aqicn.org/data-platform/token/
AQICN_API_TOKEN=your_api_key_here



# Get your free OpenWeather key at: https://openweathermap.org/api
# Required for historical backfill and weather features
OPENWEATHER_API_KEY=your_api_key_here

# ── City defaults ────────────────────────────────────────────────────────────
DEFAULT_CITY=london
DEFAULT_LAT=51.5074
DEFAULT_LON=-0.1278

# ── Hopsworks (optional — leave blank to use local storage) ──────────────────
# Sign up free at: https://app.hopsworks.ai/
HOPSWORKS_API_KEY=
HOPSWORKS_PROJECT=aqi_predictor
